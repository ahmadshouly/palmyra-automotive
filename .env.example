# ---- Copy this file to `.env` and fill in real values on the server ----

# SQLite database. In production use an ABSOLUTE path on a persistent disk, e.g.
#   DATABASE_URL="file:/var/www/palmyra-automotive/prisma/prod.db"
DATABASE_URL="file:./prod.db"

# Session signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Resend transactional email — https://resend.com/api-keys
# Leave empty to log codes to the server console instead of sending real emails.
RESEND_API_KEY=""
EMAIL_FROM="Palmyra Automotive <no-reply@palmyra-automotive.com>"
